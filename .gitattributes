# Normalize text files in the repository.
* text=auto eol=lf

# Windows command scripts require CRLF line endings.
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep common binary assets untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.jar binary
*.war binary
*.7z binary

# Avoid textual diffs for office and design artifacts.
*.doc binary
*.docx binary
*.ppt binary
*.pptx binary
*.xls binary
*.xlsx binary
*.fig binary
